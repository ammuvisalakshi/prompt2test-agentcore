# ──────────────────────────────────────────────────────────────────────────────
# Prompt2TestAgentCore — .env.example
#
# Copy this file to .env and fill in the values.
# In production (AgentCore Runtime), set these as environment variables —
# never commit a filled-in .env file to source control.
# ──────────────────────────────────────────────────────────────────────────────

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
BEDROCK_MODEL=anthropic.claude-3-5-sonnet-20241022-v2:0

# ── Browser backend ───────────────────────────────────────────────────────────
# Two modes — the app auto-selects based on whether this is set:
#
#  LOCAL mode (default, no AWS browser needed):
#    Leave blank. Requires Node.js + run: npm install -g @playwright/mcp
#    A headless Chromium subprocess is spawned automatically.
#
#  CLOUD mode (AgentCore Browser, no local install needed):
#    Provision: AWS Console → Bedrock → AgentCore → Browser → Create runtime
#    Format:    https://<runtime-id>.browser.bedrock-agentcore.<region>.amazonaws.com/mcp
#
AGENTCORE_BROWSER_ENDPOINT=

# ── AgentCore Gateway (Path 2 — add when ready for API testing) ───────────────
# Register your app's OpenAPI spec with AgentCore Gateway, then set this endpoint.
# Leave blank until you are ready to add API testing.
# AGENTCORE_GATEWAY_ENDPOINT=

# ── AgentCore Memory ──────────────────────────────────────────────────────────
# Memory Store ID for persisting saved tests and run history.
# Provision via: AWS Console → Bedrock AgentCore → Memory → Create memory store
# Leave blank to fall back to local saved_tests.json (development mode).
AGENTCORE_MEMORY_STORE_ID=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# For local dev: http://localhost:3001
# For production: https://your-cloudfront-domain.cloudfront.net
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3000

# ── OpenTelemetry (AgentCore Observability) ───────────────────────────────────
# When running inside AgentCore Runtime, the OTEL exporter is configured
# automatically. For local development, you can point to a local collector.
# Leave blank to use the default console exporter locally.
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=prompt2test-agent
