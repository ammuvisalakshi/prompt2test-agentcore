# ──────────────────────────────────────────────────────────────────────────────
# Prompt2TestAgentCore — Environment Variables
#
# Local development: Copy to .env and customize
# Production: Set these as secrets/env vars in AWS CloudShell or container runtime
# ──────────────────────────────────────────────────────────────────────────────

# ── AWS Configuration ──────────────────────────────────────────────────────────
AWS_REGION=us-east-1
BEDROCK_MODEL=anthropic.claude-3-5-sonnet-20241022-v2:0

# ── AgentCore Browser (Cloud) ─────────────────────────────────────────────────
# Set this in production (AgentCore automatically injects this)
# Leave unset for local development (uses npx @playwright/mcp --headless)
# AGENTCORE_BROWSER_ENDPOINT=https://...

# ── AgentCore Memory (Cloud) ──────────────────────────────────────────────────
# Set this in production to persist tests across deployments
# Leave unset for local development (uses ./saved_tests.json)
# AGENTCORE_MEMORY_STORE_ID=...

# ── Server Configuration ───────────────────────────────────────────────────────
# CORS origins — comma-separated list for /api/run, /api/replay, etc.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Optional: OpenTelemetry Observability ─────────────────────────────────────
# Uncomment to send traces to an OTEL collector (AgentCore auto-configures this)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_SERVICE_NAME=prompt2test-agent
